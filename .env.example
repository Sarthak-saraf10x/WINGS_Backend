# Google Places API (for fetching customer reviews)
GOOGLE_PLACES_API_KEY=your_google_places_api_key
GOOGLE_PLACE_ID=ChIJwZE4vS6_zjsRk-7ulX9EL4I

# Email Settings (for nodemailer notification alerts)
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_email_app_password
OWNER_EMAIL=your_email@gmail.com

# Google Sign-In for Admin Login
GOOGLE_CLIENT_ID=your_google_client_id_placeholder
